rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isPremium() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
    }

    match /books/{bookId} {
      allow read: if true;
      allow write: if false;

      match /comments/{commentId} {
        allow read: if resource.data.visible == true
          || (isAuth() && resource.data.userId == request.auth.uid);
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.userId == request.auth.uid;
        allow delete: if false;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isAuth();
          allow update, delete: if false;
        }
      }
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /likes/{fromUserId} {
      allow read: if isAuth() && request.auth.uid == fromUserId;
      match /targets/{toUserId} {
        allow read: if isAuth() && (request.auth.uid == fromUserId || request.auth.uid == toUserId);
        allow write: if isAuth() && request.auth.uid == fromUserId;
      }
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isPremium();
      allow update: if isAuth();
      allow delete: if false;
    }

    match /weeklySchedule/{weekId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
